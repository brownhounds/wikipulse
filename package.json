{
    "name": "dash",
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "dev": "vite --host",
        "build": "vite build",
        "preview": "vite preview",
        "lint": "tsc --noEmit && biome format && biome lint && stylelint \"src/**/*.scss\"",
        "lint:fix": "biome format --write . && biome lint --write . && stylelint \"src/**/*.scss\" --fix && tsc --noEmit",
        "lint:css": "stylelint \"src/**/*.scss\"",
        "lint:css:fix": "stylelint \"src/**/*.scss\" --fix",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "test": "vitest run",
        "test:watch": "vitest --watch",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@neuralfog/elemix": "0.2.0"
    },
    "devDependencies": {
        "@neuralfog/biome-config": "0.1.2",
        "@chromatic-com/storybook": "5.2.1",
        "@neuralfog/elemix-storybook": "0.0.1",
        "@neuralfog/ts-config": "0.1.2",
        "@storybook/addon-a11y": "10.4.1",
        "@storybook/addon-docs": "10.4.1",
        "@storybook/addon-vitest": "10.4.1",
        "@storybook/web-components-vite": "10.4.1",
        "@types/node": "25.9.1",
        "@vitest/browser-playwright": "4.1.7",
        "@vitest/coverage-v8": "4.1.7",
        "esbuild": "0.28.0",
        "jsdom": "29.1.1",
        "playwright": "1.60.0",
        "sass-embedded": "1.100.0",
        "storybook": "10.4.1",
        "stylelint": "17.12.0",
        "stylelint-config-standard-scss": "17.0.0",
        "typescript": "6.0.3",
        "vite": "8.0.14",
        "vitest": "4.1.7"
    }
}
